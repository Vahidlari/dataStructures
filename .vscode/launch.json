{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "cppdbg",
      "request": "launch",
      "name": "Debug chapter1 executable",
      "program": "${workspaceFolder}/_build/crackingCodingInterviews/chapter1/tests/chapter1_tests",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/_build/crackingCodingInterviews/chapter1",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "type": "cppdbg",
      "request": "launch",
      "name": "Debug dataStructures",
      "program": "${workspaceFolder}/_build/dataStructures/${input:dataStructure}/test/${input:dataStructure}_test",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/_build/dataStructures/${input:dataStructure}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "dataStructure",
      "type": "pickString",
      "description": "Select which data structure to debug",
      "options": [
        "linkedList",
        "binaryHeap",
        "binarySearchTree"
      ]
    }
  ]
}
